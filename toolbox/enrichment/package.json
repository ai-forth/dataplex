{
  "name": "md-fileset-tools",
  "version": "0.1.0",
  "description": "Local markdown fileset MCP tools for engineering evidence",
  "main": "dist/md-fileset",
  "bin": {
    "md-fileset": "./dist/md-fileset",
    "pcb-sim": "./dist/pcb-sim"
  },
  "scripts": {
    "build:mdtool": "npx bun build --compile --outfile dist/md-fileset src/tools/md/main.ts",
    "build:simtool": "npx bun build --compile --outfile dist/pcb-sim src/tools/sim/main.ts",
    "build": "npm run build:mdtool && npm run build:simtool",
    "run:mdtool": "npm run build:mdtool && npx @modelcontextprotocol/inspector dist/md-fileset --dir root-dir"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cac": "^7.0.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.21.2",
    "@types/node": "^25.6.0",
    "bun": "^1.3.13",
    "bun-types": "^1.3.13"
  }
}
